{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/crates/oxc_linter/src/rules.rs",
  "plugins": ["typescript", "vue"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "warn"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "*.d.ts",
    "components.d.ts"
  ]
}
